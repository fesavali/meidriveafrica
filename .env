# Server Configuration
NODE_ENV=development
PORT=3000

# App Configuration
APP_NAME=MEI DRIVE AFRICA
APP_URL=http://localhost:8000

# Feature Flags
ENABLE_MPESA=false
ENABLE_OAUTH=false

