{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "public",
  "installCommand": "",
  "framework": null,
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/register", "dest": "/public/register.html" },
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/admin-login", "dest": "/public/admin-login.html" },
    { "src": "/admin-dashboard", "dest": "/public/admin-dashboard.html" },
    { "src": "/course", "dest": "/public/course.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
