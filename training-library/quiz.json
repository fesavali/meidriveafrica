import { createClient } from '@supabase/supabase-js';
import fs from 'fs';

const SUPABASE_URL = 'https://jeksrwrzzrczamxijvwl.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Impla3Nyd3J6enJjemFteGlqdndsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg2NzYyMjAsImV4cCI6MjA5NDI1MjIyMH0.1poYpJKNFEVe2NTBkXBTH2bIHGk2yT8aqCU-OlJc4vs';

const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

const quizData = JSON.parse(fs.readFileSync('./training-library/quiz-bank.json', 'utf8'));

async function pushQuizBank() {
  console.log('📝 Pushing Quiz Bank to Supabase...\n');
  
  let totalQuestions = 0;
  let success = 0;
  let failed = 0;
  
  for (const category of quizData.categories) {
    console.log(`\n📂 Category: ${category.name}`);
    
    for (const q of category.questions) {
      const questionData = {
        category: category.name,
        question: q.question,
        options: q.options,
        correct_answer: q.correct,
        explanation: q.explanation,
        difficulty: q.difficulty
      };
      
      const { error } = await supabase
        .from('quiz_questions')
        .upsert(questionData, { onConflict: 'question' });
      
      if (error) {
        console.error(`   ❌ ${q.question.substring(0, 50)}...`);
        failed++;
      } else {
        console.log(`   ✅ ${q.question.substring(0, 50)}...`);
        success++;
      }
      totalQuestions++;
    }
  }
  
  console.log(`\n📊 Results: ${success} succeeded, ${failed} failed`);
  console.log(`📚 Total questions in Quiz Bank: ${totalQuestions}`);
  console.log('🎉 Complete!');
}

pushQuizBank();
